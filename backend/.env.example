# Maison backend environment

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/maison

# Auth — generate a long random string for production
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Stripe (TEST mode only). Leave blank to use the built-in mock payment.
STRIPE_SECRET_KEY=

# Where uploaded product images are written (served at /uploads)
UPLOAD_DIR=uploads
